// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          String     @id @default(uuid())
  sku         String     @unique
  name        String
  description String?
  price       Float      @default(10.0)
  category    String?
  ncm         String?    @default("3304.99.90") // Cosméticos
  cfop        String     @default("5102")        // Venda dentro do estado
  cst         String     @default("400")          // CSOSN Simples Nacional
  unidade     String     @default("UN")
  stock       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  saleItems   SaleItem[]
}

model Sale {
  id               String         @id @default(uuid())
  total            Float
  paymentMethod    String         // DINHEIRO, PIX, CARTAO_CREDITO, CARTAO_DEBITO
  status           String         @default("COMPLETED") // COMPLETED, CANCELLED
  cashierSessionId String
  cashierSession   CashierSession @relation(fields: [cashierSessionId], references: [id])
  items            SaleItem[]
  cpfConsumidor    String?        // CPF do consumidor (opcional)

  // Campos Fiscais NFC-e
  nfceRef       String?  // Referência interna enviada ao integrador
  nfceStatus    String?  // PENDENTE, AUTORIZADO, REJEITADO, CANCELADO
  nfceChave     String?  // Chave de acesso (44 dígitos)
  nfceNumero    Int?     // Número sequencial da nota
  nfceSerie     Int?     // Série da nota
  nfceQrCode    String?  // URL do QR Code para consulta
  nfceXmlUrl    String?  // URL do XML assinado
  nfceDanfceUrl String?  // URL do PDF DANFC-e
  nfceEmitidoEm DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SaleItem {
  id        String   @id @default(uuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  createdAt DateTime @default(now())
}

model CashierSession {
  id            String    @id @default(uuid())
  userId        String
  openedAt      DateTime  @default(now())
  closedAt      DateTime?
  initialAmount Float     @default(0.0)
  finalAmount   Float?
  status        String    @default("OPEN") // OPEN, CLOSED
  sales         Sale[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model StoreConfig {
  id               String   @id @default("default")
  // Dados da Empresa
  cnpj             String   @default("11222333000181")
  razaoSocial      String   @default("BELLA MAKE COMERCIO DE COSMETICOS LTDA")
  nomeFantasia     String   @default("Bella Make")
  ie               String   @default("111222333444")
  crt              Int      @default(1) // 1 = Simples Nacional
  // Endereço
  logradouro       String   @default("Rua das Flores")
  numero           String   @default("100")
  bairro           String   @default("Centro")
  municipio        String   @default("São Paulo")
  uf               String   @default("SP")
  cep              String   @default("01310100")
  telefone         String?  @default("11999999999")
  // Configuração Fiscal
  focusNfeToken    String   @default("SIMULADO")
  focusNfeAmbiente String   @default("homologacao") // homologacao | producao
  nfceSerie        Int      @default(1)
  nfceUltNumero    Int      @default(0)
  modoSimulacao    Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
